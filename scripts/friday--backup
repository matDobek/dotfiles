#!/usr/bin/env bash

set -euo pipefail

####################
# config
####################

sources=(
  "/home/cr0xd/main"
  "/home/cr0xd/.ssh"
)

excludes=(
  # js
  "node_modules"

  # rust
  "target"
  "debug"

  # elixir
  "_build"
  ".elixir_ls"
  "deps"

  # python
  "__pycache__"

  # general
  ".cache"
  "*.tmp"
)

hetzner_retention=(
  --keep-daily 7
  --keep-weekly 4
  --keep-monthly 12
  --keep-yearly 3
)

# USB is small (14 GB) - keep only the latest snapshot.
usb_retention=(
  --keep-last 1
)

usb_label="backup"
usb_mount="/media/usb"
usb_repo_path="restic/friday"

# Hetzner connection details live in ~/.ssh/config under the "backup" host.
hetzner_ssh_host="backup"
hetzner_repo_path="restic/friday"

####################
# helpers
####################

function decho() {
  echo
  echo "---------------"
  echo "$1"
  echo "---------------"
}

function confirm() {
  read -r -p "$1 [y/N] " reply
  [[ "$reply" =~ ^[Yy]$ ]]
}

####################
# verify
####################

if (( $(id -u) == 0 )); then
  echo "--- Run as user, not root (script uses sudo only when mounting)."
  exit 1
fi

command -v restic >/dev/null || { echo "restic not installed."; exit 1; }

for src in "${sources[@]}"; do
  if [[ ! -e "$src" ]]; then
    echo "Source missing: $src"
    exit 1
  fi
done

####################
# restic passphrase (prompt once, share with both repos for this run only)
####################

read -rsp "Restic passphrase: " RESTIC_PASSWORD
echo
export RESTIC_PASSWORD

####################
# exclude args
####################

exclude_args=()
for item in "${excludes[@]}"; do
  exclude_args+=(--exclude "$item")
done

####################
# backup function
####################

function backup_to_repo() {
  local label="$1"
  local repo="$2"
  local -n retention_ref="$3"

  decho "Backup to ${label}"
  echo "Repo: ${repo}"

  restic -r "$repo" backup \
    --verbose \
    --one-file-system \
    "${exclude_args[@]}" \
    "${sources[@]}"

  decho "Forget + prune at ${label}"
  restic -r "$repo" forget "${retention_ref[@]}" --prune

  decho "Quick integrity check at ${label}"
  restic -r "$repo" check
}

####################
# USB
####################

usb_available=0
if [[ -e "/dev/disk/by-label/${usb_label}" ]]; then
  if ! mountpoint -q "$usb_mount"; then
    sudo mkdir -p "$usb_mount"
    sudo mount "/dev/disk/by-label/${usb_label}" "$usb_mount"
  fi
  usb_available=1
  trap 'mountpoint -q "'"$usb_mount"'" && sudo umount "'"$usb_mount"'" || true' EXIT
fi

if (( usb_available )); then
  backup_to_repo "USB" "${usb_mount}/${usb_repo_path}" usb_retention
else
  echo
  echo "USB not present (label: ${usb_label}). Skipping USB backup."
fi

####################
# Hetzner
####################

hetzner_repo="sftp:${hetzner_ssh_host}:${hetzner_repo_path}"

backup_to_repo "Hetzner" "$hetzner_repo" hetzner_retention

decho "Done"
